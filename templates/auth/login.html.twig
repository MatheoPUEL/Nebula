{% extends 'base_no-nav.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}


    <div class="d-flex flex-column align-items-center h-100 px-3 px-lg-5 pt-5">
        <div class="w-100 mt-auto" style="max-width: 526px;">
            <h1>{{ 'sign_in'|trans }}</h1>
            <p class="pb-3 mb-3 mb-lg-4">{{ 'no_account'|trans }}?&nbsp;&nbsp;<a href="{{ path('app_register') }}">{{ 'register'|trans }}</a></p>
            <form method="post" class="needs-validation" novalidate>

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-primary">
                            {{ message }}
                        </div>
                    {% endfor %}
                    {% if error %}
                        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                {% if app.user %}
                    <div class="alert alert-warning mb-3">
                        You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
                    </div>
                {% endif %}
                <div class="pb-3 mb-3">
                    <div class="position-relative">
                        <i class="ai-mail fs-lg position-absolute top-50 start-0 translate-middle-y ms-3"></i>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control form-control-lg ps-5" autocomplete="email" placeholder="{{ 'Email'|trans }}" required autofocus>
                    </div>
                </div>
                <div class="pb-3 mb-3">
                    <div class="position-relative">
                        <i class="ai-lock-closed fs-lg position-absolute top-50 start-0 translate-middle-y ms-3"></i>
                        <input type="password" name="_password" id="password" class="form-control form-control-lg ps-5" autocomplete="current-password" placeholder="{{ 'pwd'|trans }}" required>
                    </div>
                </div>
                <input type="hidden" name="_csrf_token"
                       value="{{ csrf_token('authenticate') }}"
                >

                {#
                Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                See https://symfony.com/doc/current/security/remember_me.html

                <div class="checkbox mb-3">
                    <input type="checkbox" name="_remember_me" id="_remember_me">
                    <label for="_remember_me">Remember me</label>
                </div>
                #}
                <div class="d-flex flex-wrap align-items-center justify-content-between pb-4">
                    <div class="form-check my-1">
                        <input class="form-check-input" type="checkbox" id="keep-signedin">
                        <label class="form-check-label ms-1" for="keep-signedin">Keep me signed in</label>
                    </div>
                    <a class="fs-sm fw-semibold text-decoration-none my-1" href="{{ path('app_forgot_password_request') }}">{{ 'forgot_password'|trans }}</a>
                </div>
                <button class="btn btn-lg btn-primary w-100 mb-4" type="submit">{{ 'sign_in'|trans }}</button>

            </form>
        </div>

        <!-- Copyright -->
        <p class="nav w-100 fs-sm pt-5 mt-auto mb-5" style="max-width: 526px;"><span class="text-body-secondary">© All rights reserved. Made by</span><a class="nav-link d-inline-block p-0 ms-1" href="https://createx.studio/" target="_blank" rel="noopener">Createx Studio</a></p>
    </div>

{% endblock %}
